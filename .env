# =====================================================
# 赛博电视台 - 环境配置
# =====================================================

# 多推流地址配置 (JSON 格式数组)
# 格式: ["地址1", "地址2", ...]
# RTMP_URLS=["rtmp://server1/live/stream1", "rtmp://server2/live/stream2"]

# 单推流地址
RTMP_URL=rtmp://sendhw3.douyu.com/live/12816797rGFR4mHZ?dyPRI=0&noforward=1&origin=hw&record=flv&roirecognition=0&stemp_id=12898962&tw=0&wm=0&wsSecret=2bb8438f8147804249b83649c51f26ba&wsSeek=off&wsTime=69c24276

# 视频码率 (低配服务器建议 1000k-2000k)
VIDEO_BITRATE=1500k

# 内容更新间隔 (秒)
UPDATE_INTERVAL=60

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用音频 (需要准备音频文件)
ENABLE_AUDIO=false
