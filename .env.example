# =====================================================
# 赛博电视台 - 环境配置
# =====================================================
# 复制此文件为 .env 并根据实际情况修改

# RTMP 推流地址
# 示例: rtmp://your-server/live/stream
RTMP_URL=rtmp://localhost/live/stream

# 视频码率 (低配服务器建议 1000k-2000k)
VIDEO_BITRATE=1500k

# 内容更新间隔 (秒)
UPDATE_INTERVAL=60

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用音频 (需要准备音频文件)
ENABLE_AUDIO=false

# 音频文件路径
AUDIO_FILE=data/voice.mp3
